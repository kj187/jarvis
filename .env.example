# .env — Jarvis Konfiguration

# Server
JARVIS_PORT=8080
JARVIS_LOG_LEVEL=info          # info | debug
JARVIS_POLL_INTERVAL=15s

# Database — JARVIS_DB_DSN accepts either:
#   SQLite:     a file path                              (default: /data/jarvis.db)
#   PostgreSQL: a postgres:// URL
JARVIS_DB_DSN=/data/jarvis.db
# JARVIS_DB_DSN=postgres://jarvis:secret@postgres:5432/jarvis?sslmode=disable
# Optional: Base URL for runbook links (value of label "runbook" is appended)
# Example: JARVIS_RUNBOOK_BASE_URL=https://wiki.example.com/runbooks/
JARVIS_RUNBOOK_BASE_URL=
# CORS: comma-separated list of allowed browser origins (no wildcard *).
# Also used as origin whitelist for WebSocket upgrade (CheckOrigin).
# Default when empty: same origin as the server (same-origin only).
JARVIS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Cluster 1 ────────────────────────────────────────────────
JARVIS_CLUSTER_1_NAME=homelab
JARVIS_CLUSTER_1_ALERTMANAGER_URL=http://alertmanager:9093
# HOST_ALIAS: Optional — overrides host/scheme for browser links
# Useful when internal API URL ≠ browser URL (e.g. localhost vs. hostname)
JARVIS_CLUSTER_1_HOST_ALIAS=https://alertmanager.lan.example.com
JARVIS_CLUSTER_1_PROMETHEUS_URL=http://prometheus:9090

# ── Cluster 2 ────────────────────────────────────────────────
# JARVIS_CLUSTER_2_NAME=production
# JARVIS_CLUSTER_2_ALERTMANAGER_URL=http://prod-alertmanager:9093
# JARVIS_CLUSTER_2_PROMETHEUS_URL=http://prod-prometheus:9090
# JARVIS_CLUSTER_2_HOST_ALIAS=

# Add more clusters: JARVIS_CLUSTER_N_NAME, _ALERTMANAGER_URL, _PROMETHEUS_URL, _HOST_ALIAS
