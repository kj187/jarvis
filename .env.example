# .env — Jarvis Konfiguration

# Server
JARVIS_PORT=8080
JARVIS_LOG_LEVEL=info          # info | debug
JARVIS_POLL_INTERVAL=15s

# Database — JARVIS_DB_DSN accepts either:
#   SQLite:     a file path                              (default: /data/jarvis.db)
#   PostgreSQL: a postgres:// URL
JARVIS_DB_DSN=/data/jarvis.db
# JARVIS_DB_DSN=postgres://jarvis:secret@postgres:5432/jarvis?sslmode=require
# Use sslmode=require (or verify-full) in production.
# sslmode=disable is only acceptable for local ephemeral test containers.

# Optional: Base URL for runbook links.
# Applied when the "runbook" label or annotation value is NOT an absolute URL.
# The label/annotation value is appended to form the final URL.
# Example: JARVIS_RUNBOOK_BASE_URL=https://wiki.example.com/runbooks/
#          runbook=my-alert  →  https://wiki.example.com/runbooks/my-alert
# If the runbook value is already an absolute URL (http:// or https://), it is used as-is.
# Any other label or annotation with an absolute URL value automatically renders as a link button.
JARVIS_RUNBOOK_BASE_URL=

# CORS: comma-separated list of allowed browser origins (no wildcard *).
# Also used as origin whitelist for WebSocket upgrade (CheckOrigin).
# Default when empty: same origin as the server (same-origin only).
JARVIS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Authentication ────────────────────────────────────────────
# JARVIS_AUTH_PROVIDER controls the authentication mode:
#   none     (default) — No authentication. Write actions (claims, comments, silences)
#                        are publicly accessible. Users enter their name manually.
#                        A warning banner is shown in the UI.
#   internal           — Per-user accounts stored in the local DB with bcrypt passwords.
#                        First-run wizard creates the admin account at /setup.
#   oidc               — OIDC Authorization Code Flow with PKCE (e.g. Keycloak, Authentik).
JARVIS_AUTH_PROVIDER=none

# JARVIS_AUTH_MODE controls the protection level when JARVIS_AUTH_PROVIDER != none.
# Ignored (forced to "none") when JARVIS_AUTH_PROVIDER=none.
#   write_protect  (default) — Unauthenticated users can view alerts read-only;
#                              write operations (claim, comment, silence) require login.
#   full_protect             — All routes require login; unauthenticated users see only
#                              the login page.
# JARVIS_AUTH_MODE=write_protect

# Required when JARVIS_AUTH_PROVIDER != none.
# Generate a secure key: openssl rand -hex 32
# JARVIS_SECRET_KEY=<min 32 random bytes, hex or raw string>

# ── OIDC settings (only required when JARVIS_AUTH_PROVIDER=oidc) ──────────────
# JARVIS_AUTH_OIDC_ISSUER=https://keycloak.example.com/realms/myrealm
# JARVIS_AUTH_OIDC_CLIENT_ID=jarvis
# JARVIS_AUTH_OIDC_CLIENT_SECRET=           # optional for PKCE-only clients
# JARVIS_AUTH_OIDC_REDIRECT_URL=https://jarvis.example.com/auth/oidc/callback
# JARVIS_AUTH_OIDC_SCOPES=openid,profile,email   # default

# ── Cluster 1 ────────────────────────────────────────────────
JARVIS_CLUSTER_1_NAME=homelab
JARVIS_CLUSTER_1_ALERTMANAGER_URL=http://alertmanager:9093
# HA gossip cluster: comma-separated member list instead of one URL — dedups
# alerts by fingerprint across members, stays healthy if any member is up.
# Local testing pair: `make up-alertmanager-ha` (compose.dev-dependencies.yml)
# JARVIS_CLUSTER_1_ALERTMANAGER_URL=http://test-alertmanager:9093,http://test-alertmanager-2:9093
# HOST_ALIAS: Optional — overrides host/scheme for browser links
# Useful when internal API URL ≠ browser URL (e.g. localhost vs. hostname)
JARVIS_CLUSTER_1_HOST_ALIAS=https://alertmanager.lan.example.com
# HA cluster: one alias applies to all members, or a comma-separated list
# index-matched to ALERTMANAGER_URL (e.g. each member on its own localhost port):
# JARVIS_CLUSTER_1_HOST_ALIAS=http://localhost:9094,http://localhost:9095
JARVIS_CLUSTER_1_PROMETHEUS_URL=http://prometheus:9090
# Upstream Alertmanager auth (optional) — see docs/authentication-alertmanager.md
# Priority: OAuth2 > BEARER_TOKEN > BASIC_AUTH > HEADER_*
# OAuth2 client_credentials (recommended — auto token refresh):
# JARVIS_CLUSTER_1_OAUTH2_CLIENT_ID=jarvis
# JARVIS_CLUSTER_1_OAUTH2_CLIENT_SECRET=secret
# JARVIS_CLUSTER_1_OAUTH2_TOKEN_URL=https://keycloak.example.com/realms/myrealm/protocol/openid-connect/token
# JARVIS_CLUSTER_1_OAUTH2_SCOPES=openid,profile
# Static bearer token:
# JARVIS_CLUSTER_1_BEARER_TOKEN=
# Basic auth:
# JARVIS_CLUSTER_1_BASIC_AUTH_USER=
# JARVIS_CLUSTER_1_BASIC_AUTH_PASSWORD=
# Custom header (repeat for multiple):
# JARVIS_CLUSTER_1_HEADER_X-My-Header=value

# ── Cluster 2 ────────────────────────────────────────────────
# JARVIS_CLUSTER_2_NAME=production
# JARVIS_CLUSTER_2_ALERTMANAGER_URL=http://prod-alertmanager:9093
# JARVIS_CLUSTER_2_PROMETHEUS_URL=http://prod-prometheus:9090
# JARVIS_CLUSTER_2_HOST_ALIAS=

# Add more clusters: JARVIS_CLUSTER_N_NAME, _ALERTMANAGER_URL, _PROMETHEUS_URL, _HOST_ALIAS
