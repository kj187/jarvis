#!/usr/bin/env bash
set -euo pipefail

echo "▶ Running pre-commit checks..."

# ── Go checks (only if backend files changed) ─────────────────────────────────
if git diff --cached --name-only | grep -q "^backend/"; then
  echo "  [Go] Running unit tests..."
  (cd backend && go test ./... -count=1 -timeout 60s)

  # gosec runs as part of golangci-lint (enabled in .golangci.yml).
  # govulncheck runs in CI only: its result depends on the vulnerability DB,
  # not on the staged changes, and it needs network access.
  echo "  [Go] Running golangci-lint..."
  (cd backend && golangci-lint run ./...)
fi

# ── Frontend checks (only if frontend files changed) ──────────────────────────
if git diff --cached --name-only | grep -q "^frontend/"; then
  FRONTEND_CONTAINER="jarvis_frontend_1"
  if podman exec "$FRONTEND_CONTAINER" true 2>/dev/null; then
    echo "  [Frontend] Running pnpm audit..."
    podman exec -e CI=true "$FRONTEND_CONTAINER" sh -c "cd /app && pnpm audit --audit-level=high"
    echo "  [Frontend] Running eslint..."
    podman exec -e CI=true "$FRONTEND_CONTAINER" sh -c "cd /app && pnpm lint"
    echo "  [Frontend] Running unit tests (lib/alertUtils.ts, with coverage gate)..."
    podman exec -e CI=true "$FRONTEND_CONTAINER" sh -c "cd /app && pnpm test:unit:coverage"
    echo "  [Frontend] Running jscpd (code duplication)..."
    podman exec -e CI=true "$FRONTEND_CONTAINER" sh -c "cd /app && pnpm duplication"
  else
    echo "  [Frontend] Container '$FRONTEND_CONTAINER' not running — start with: podman compose -f compose.dev.yml up"
    exit 1
  fi
fi

# ── Helm checks (only if chart files changed) ─────────────────────────────────
if git diff --cached --name-only | grep -q "^charts/"; then
  echo "  [Helm] Running helm lint..."
  helm lint charts/jarvis/

  echo "  [Helm] Running helm unittest..."
  helm unittest charts/jarvis/
fi

# ── Secret scanning (always, all file types) ──────────────────────────────────
echo "  [Security] Running gitleaks (secret scan)..."
git diff --cached | podman run --rm -i \
  -v "$PWD/.gitleaks.toml:/repo/.gitleaks.toml:ro,z" \
  zricethezav/gitleaks:latest detect --pipe --redact -c /repo/.gitleaks.toml

echo "✅ All pre-commit checks passed."
